# ── Webinar Dashboard backend ───────────────────────────────────────────────
PORT=3005
CLIENT_ORIGIN=http://localhost:5194

# Shared Postgres (same DB as the other services). This backend ONLY creates
# and touches its own isolated wd_* tables — it never reads funnel/CRM data.
DATABASE_URL=

# ── Zoom Server-to-Server OAuth (ONE app on the MAIN Zoom account) ───────────
# Create at marketplace.zoom.us → Develop → Build App → "Server-to-Server OAuth".
# Add these scopes:
#   meeting:write:admin        (create meetings under any host)
#   meeting:read:admin         (read meeting + registrants/phone)
#   report:read:admin          (participant report: name / email / duration)
#   cloud_recording:read:admin (optional — saved chat file for chat messages)
# Participant reports + registration require a paid Zoom plan (Pro or higher).
# Leave these blank to run in FALLBACK mode (cards still save; no live meeting).
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# The 5 host users a meeting can be created under (the "5 accounts under one
# main account" model). Comma-separated, "Label=email" (or just the email):
# ZOOM_HOSTS=Host A=a@org.com,Host B=b@org.com,Host C=c@org.com,Host D=d@org.com,Host E=e@org.com
ZOOM_HOSTS=
