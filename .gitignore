# ── Dependencies ────────────────────────────────────────────────────
node_modules/

# ── Build output ───────────────────────────────────────────────────
dist/
.vite/
build/

# ── Environment files ──────────────────────────────────────────────
# NEVER commit secrets (DB url, JWT secret, Tata API key, etc.)
.env
.env.*
.env.local
.env.*.local
!.env.example

# ── Logs ───────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Test coverage ──────────────────────────────────────────────────
**/coverage/

# ── Claude / editor ────────────────────────────────────────────────
.claude/

# ── Vercel ─────────────────────────────────────────────────────────
.vercel/
*.env.prod.check
*.env.verify
*.env.vercel.local

# ── Render-style scratch dirs ──────────────────────────────────────
.render/

# ── Runtime artifacts (recordings + uploads regenerate per service) ─
**/uploads/*
!**/uploads/.gitkeep

# ── Persisted admin secret (contains password + JWT secret) ─────────
# Each environment generates its own at first boot.
**/backend/data/admin.json

# ── Local-only / backup folders (NOT part of the codebase) ─────────
nsl - original - Copy/
.dev-logs/
