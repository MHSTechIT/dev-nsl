# ─────────────────────────────────────────────────────────────────────
# Tata Smartflo (Click-to-Call + recordings)
# Get these from your Tata account manager / Smartflo admin panel.
#
# Until at least TATA_API_BASE_URL + (TATA_API_TOKEN or TATA_API_KEY)
# are set, the call button works in "stub mode" — it inserts a calls
# row with a fake provider_call_id but does not dial a real call.
#
# Per-agent settings (account_type, extension, agent_number, caller_id)
# are stored on the CRM user row, NOT here. Set them in the
# Create/Edit User form for each Junior Caller / Senior Caller.
# ─────────────────────────────────────────────────────────────────────
TATA_API_BASE_URL=https://api-smartflo.tatatele.com
TATA_API_PATH=/v1/click_to_call_support
TATA_API_TOKEN=
TATA_API_KEY=
TATA_CALLER_ID=
TATA_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Meta Conversions API (server-side pixel mirror)
# Pairs with frontend/src/utils/metaPixel.js. Every event the browser
# fires via fbq is mirrored to /api/meta/event → routes/meta.js →
# utils/metaCapi.js → Graph API /events with the same event_id.
# Meta dedupes the browser + server events via event_id, so we get
# one conversion record per real lead even when the browser pixel is
# blocked by ad-blockers / Safari ITP.
#
# Find these in Events Manager → Data Sources → your pixel:
#   PIXEL_ID           → the 16-digit pixel ID (URL or "Settings" tab)
#   ACCESS_TOKEN       → Settings → Conversions API → Generate access token
#   TEST_EVENT_CODE    → Test Events tab → "Code" badge (e.g. TEST69061)
#                        Leave empty in production. When set, events
#                        route to the Test Events panel instead of
#                        live conversion volume.
#   API_VERSION        → Optional. Defaults to v18.0 which Meta supports
#                        as of 2025-09 (latest GA).
# ─────────────────────────────────────────────────────────────────────
META_PIXEL_ID=1866739047322363
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=
META_CAPI_API_VERSION=v18.0
